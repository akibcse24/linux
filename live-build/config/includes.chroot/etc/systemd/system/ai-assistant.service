[Unit]
Description=ctx0an AI Assistant Daemon
After=network-online.target ollama.service live-config.service
Wants=network-online.target

[Service]
Type=simple
User=root
Environment=CTX0AN_ASSISTANT_BIND=127.0.0.1:8811
ExecStart=/usr/local/bin/ai-assistantd
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target