# Tint2 config file for Opera GX Gaming Theme
# Backgrounds
rounded = 0
border_width = 1
border_color = #ff0033 100
background_color = #0b0b0c 100

# Active task background
rounded = 2
border_width = 1
border_color = #ff0033 100
background_color = #1a080c 100

# Normal task background
rounded = 2
border_width = 0
border_color = #000000 0
background_color = #141416 100

# Panel
panel_monitor = all
panel_position = bottom center horizontal
panel_size = 100% 32
panel_margin = 0 0
panel_padding = 4 4 4
panel_background_id = 1
wm_menu = 1

# Taskbar
taskbar_mode = single_desktop
taskbar_padding = 2 2 2
taskbar_background_id = 0
taskbar_active_background_id = 0

# Tasks
task_icon = 1
task_text = 1
task_width = 160
task_centered = 1
task_padding = 4 2
task_font = Sans 9
task_font_color = #eeeeee 100
task_active_font_color = #ffffff 100
task_background_id = 3
task_active_background_id = 2

# Systray
systray_padding = 4 2 4
systray_background_id = 0
systray_sort = ascending
systray_icon_size = 18
systray_icon_ascent = 0

# Clock
time1_format = %H:%M
time1_font = Sans Bold 9
time1_font_color = #ff0033 100
time_padding = 6 0
time_background_id = 0
